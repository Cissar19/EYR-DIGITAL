rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Imágenes de preguntas: cualquier usuario autenticado puede leer y escribir
    match /evaluaciones/{allPaths=**} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null;
    }

    // Plantilla de prueba: lectura para todos los autenticados,
    // escritura solo para admin/super_admin/utp_head
    match /app_config/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && get(/databases/(default)/documents/users/$(request.auth.uid)).data.role
           in ['super_admin', 'admin', 'utp_head'];
    }

  }
}
