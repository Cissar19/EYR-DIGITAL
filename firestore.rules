rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================
    // HELPER FUNCTIONS
    // ============================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserRole() {
      // Always read from Firestore (source of truth). JWT claims can be stale
      // if the role was changed directly in Firestore or without a token refresh,
      // causing false permission denials even for legitimate admins.
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isAuthenticated() && getUserRole() in ['admin', 'super_admin'];
    }

    function isSuperAdmin() {
      return isAuthenticated() && getUserRole() == 'super_admin';
    }

    function isManagement() {
      return isAuthenticated() && getUserRole() in ['admin', 'super_admin', 'director', 'utp_head', 'inspector', 'convivencia_head'];
    }

    function isConvivenciaOrAdmin() {
      return isAuthenticated() && getUserRole() in ['convivencia', 'convivencia_head', 'admin', 'super_admin'];
    }

    function isPrinterOrAdmin() {
      return isAuthenticated() && getUserRole() in ['printer', 'admin', 'super_admin'];
    }

    function isUTP() {
      return isAuthenticated() && getUserRole() in ['utp_head', 'admin', 'super_admin'];
    }

    function isEnfermeria() {
      return isAuthenticated() && getUserRole() in ['staff', 'pie', 'admin', 'super_admin', 'director', 'utp_head', 'inspector', 'convivencia_head'];
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Verifica que el profesor tenga el par curso|asignatura en su horario guardado.
    // Soporta tanto el formato nuevo (courseSubjectPairs) como horarios legacy (solo blocks).
    function teacherScheduleAllows(userId, curso, asignatura) {
      let ref = /databases/$(database)/documents/schedules/$(userId);
      return exists(ref) && (
        get(ref).data.get('courseSubjectPairs', null) == null
          ? get(ref).data.get('blocks', []).size() > 0
          : get(ref).data.get('courseSubjectPairs', []).hasAny([curso + '|' + asignatura])
      );
    }

    // ============================================
    // USERS COLLECTION
    // ============================================
    match /users/{userId} {
      allow read: if isAuthenticated();

      // Only admins can create users
      allow create: if isAdmin();

      // Users can update own profile (except role/uid/email), admins can update anyone
      allow update: if isAuthenticated() && (
        (isOwner(userId) && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'uid', 'email']))
        || isAdmin()
      );

      // Only admins can delete, cannot delete self
      allow delete: if isAdmin() && !isOwner(userId);
    }

    // ============================================
    // ADMINISTRATIVE DAYS
    // ============================================
    match /admin_requests/{docId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isManagement();
      allow delete: if isManagement();
    }

    match /admin_metrics/{userId} {
      allow read: if isAuthenticated();
      allow write: if isManagement();
    }

    // ============================================
    // TICKETS
    // ============================================
    match /tickets/{ticketId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isManagement();
      allow delete: if isManagement();
    }

    // ============================================
    // LAB RESERVATIONS
    // ============================================
    match /lab_reservations/{docId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow delete: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
      allow update: if isAdmin();
    }

    // ============================================
    // PRINT REQUESTS
    // ============================================
    match /print_requests/{docId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isPrinterOrAdmin();
      allow delete: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || isPrinterOrAdmin()
      );
    }

    // ============================================
    // EQUIPMENT & FOLDERS
    // ============================================
    match /equipment/{docId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }

    match /equipment_folders/{docId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }

    match /equipment_requests/{docId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }

    // ============================================
    // MEDICAL LEAVES
    // ============================================
    match /medical_leaves/{docId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isManagement();
    }

    // ============================================
    // SCHEDULES
    // ============================================
    match /schedules/{docId} {
      allow read: if isAuthenticated();
      allow write: if isManagement() || isAdmin();
    }

    match /course_schedules/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ============================================
    // INVENTORY
    // ============================================
    match /inventory_categories/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /inventory_items/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ============================================
    // CONVIVENCIA RESERVATIONS
    // ============================================
    match /convivencia_reservations/{docId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow delete: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || isConvivenciaOrAdmin()
      );
      allow update: if isConvivenciaOrAdmin();
    }

    // ============================================
    // CONVIVENCIA BLOCKS (Blocked Slots)
    // ============================================
    match /convivencia_blocks/{docId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isConvivenciaOrAdmin();
    }

    // ============================================
    // STUDENTS (Convivencia)
    // ============================================
    match /students/{docId} {
      allow read: if isAuthenticated();
      allow create, update: if isConvivenciaOrAdmin();
      allow delete: if isConvivenciaOrAdmin();
    }

    // ============================================
    // CONVIVENCIA INCIDENTS
    // ============================================
    match /convivencia_incidents/{docId} {
      allow read: if isConvivenciaOrAdmin();
      allow create, update: if isConvivenciaOrAdmin();
      allow delete: if isAdmin();
    }

    // ============================================
    // JUSTIFICATIVES (Inspectoría)
    // ============================================
    match /justificatives/{docId} {
      allow read: if isAuthenticated() && isManagement();
      allow write: if isAuthenticated() && isManagement();
    }

    // ============================================
    // ENTREVISTAS (Inspectoría)
    // ============================================
    match /entrevistas/{docId} {
      allow read: if isAuthenticated() && isManagement();
      allow write: if isAuthenticated() && isManagement();
    }

    // ============================================
    // PERMISSIONS & REPLACEMENT LOGS
    // ============================================
    match /permissions_role_defaults/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /replacement_logs/{docId} {
      allow read: if isAuthenticated();
      allow write: if isManagement();
    }

    // ============================================
    // TEACHER HOURS (Entry/Exit Schedules)
    // ============================================
    match /teacher_hours/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ============================================
    // ATTENDANCE REPORTS
    // ============================================
    match /attendance_reports/{docId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isManagement();
    }

    // ============================================
    // EVALUACIONES UTP
    // ============================================
    match /evaluaciones/{docId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && (
        isManagement() ||
        (getUserRole() in ['teacher', 'docente_volante'] && teacherScheduleAllows(request.auth.uid, request.resource.data.curso, request.resource.data.asignatura))
      );
      allow update: if isAuthenticated() && (
        isManagement() ||
        (getUserRole() in ['teacher', 'docente_volante'] && teacherScheduleAllows(request.auth.uid, resource.data.curso, resource.data.asignatura))
      );
      allow delete: if isAuthenticated() && (
        isManagement() ||
        (getUserRole() in ['teacher', 'docente_volante'] && resource.data.createdBy.id == request.auth.uid)
      );
    }

    // ============================================
    // CONTROL SANO (Enfermería)
    // ============================================
    match /control_sano/{docId} {
      allow read: if isEnfermeria();
      allow create, update: if isEnfermeria();
      allow delete: if isAdmin();
    }

    // ============================================
    // ATENCIONES DIARIAS (Enfermería)
    // ============================================
    match /atenciones_diarias/{docId} {
      allow read: if isEnfermeria();
      allow create, update: if isEnfermeria();
      allow delete: if isAdmin();
    }

    // ============================================
    // FICHA CLAP (Enfermería - 4° a 8° Básico)
    // ============================================
    match /ficha_clap/{docId} {
      allow read: if isEnfermeria();
      allow create, update: if isEnfermeria();
      allow delete: if isAdmin();
    }

    // ============================================
    // CUSTOM ROLES
    // ============================================
    match /roles/{roleKey} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }

    // ============================================
    // EYR NO PIERDE CLASES
    // ============================================

    match /retos/{retoId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() &&
        getUserRole() in ['super_admin', 'admin', 'utp_head', 'teacher', 'docente_volante'];
      allow delete: if isAdmin();
    }

    match /sesiones_reto/{sesionId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() &&
        getUserRole() in ['super_admin', 'admin', 'director', 'inspector', 'staff'];
      allow update: if isAuthenticated() && (
        resource.data.asistente.uid == request.auth.uid || isManagement()
      );
      allow delete: if isAdmin();
    }

    match /respuestas_reto/{respId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      // Anonymous students (role == null) can update any respuesta doc.
      // Page refresh gives a new anon uid, so we can't restrict by anonUid alone.
      allow update: if isAuthenticated() && (
        request.auth.token.role == null ||
        isManagement()
      );
      allow delete: if isAdmin();
    }

    // ============================================
    // APP CONFIG (formato de prueba, plantilla UTP)
    // ============================================
    match /app_config/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && getUserRole() in ['super_admin', 'admin', 'utp_head'];
    }

    // ============================================
    // FORMATOS PRUEBA (UTP)
    // ============================================
    match /formatos_prueba/{docId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAuthenticated() && getUserRole() in ['super_admin', 'admin', 'utp_head'];
    }

    // ============================================
    // CURRICULUM OA (MINEDUC)
    // ============================================
    match /curriculum/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ============================================
    // BANCO DE PREGUNTAS (UTP)
    // ============================================
    match /question_bank/{docId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (
        resource.data.createdBy.id == request.auth.uid || isManagement()
      );
      allow delete: if isAuthenticated() && (
        resource.data.createdBy.id == request.auth.uid || isAdmin()
      );
    }
    // ── WORKSHOPS ─────────────────────────────────────────────────────────────
    match /workshops/{workshopId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated() && (
        resource.data.createdBy == request.auth.uid || isAdmin()
      );
    }

    // ── PERSONAL TODOS ──────────────────────────────────────────────────────
    match /todos/{todoId} {
      allow read, update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
    }

    // ── TASKS ──────────────────────────────────────────────────────────────
    match /tasks/{taskId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (
        resource.data.createdBy == request.auth.uid ||
        resource.data.assignedTo == request.auth.uid ||
        isManagement()
      );
      allow delete: if isAuthenticated() && (
        resource.data.createdBy == request.auth.uid || isAdmin()
      );
    }

    // ============================================
    // COBERTURA CURRICULAR
    // ============================================
    match /schools/{schoolId}/academicYears/{year} {
      allow read: if isAuthenticated();
      allow write: if isUTP();
    }

    match /schools/{schoolId}/academicYears/{year}/coverage/{docId} {
      allow read: if isAuthenticated();
      // No permitir writes si el año está cerrado (active == false)
      allow create, update, delete: if isUTP() &&
        get(/databases/$(database)/documents/schools/$(schoolId)/academicYears/$(year)).data.get('active', true) != false;
    }

    // OAs por año (nueva estructura: curriculum/{year}/oas/{oaId})
    // La regla /curriculum/{docId} cubre los docs planos heredados (lectura legacy).
    match /curriculum/{year}/oas/{oaId} {
      allow read: if isAuthenticated();
      allow write: if isUTP();
    }

    // ============================================
    // AGENDA SEMANAL (UTP)
    // ============================================
    match /agenda_semanal/{entryId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin() || isUTP();
    }

    match /agenda_noticias/{notId} {
      allow read: if isAuthenticated();
      // El docente solo puede crear noticias bajo su propio uid
      allow create: if isAuthenticated() &&
        request.resource.data.docenteId == request.auth.uid;
      // El docente edita/borra las suyas; admin/UTP puede borrar cualquiera
      allow update, delete: if isAuthenticated() && (
        resource.data.docenteId == request.auth.uid ||
        isAdmin() || isUTP()
      );
    }

    // ============================================
    // INCENTIVO-EYR (banco de estrellas)
    // ============================================
    function isIncentivoUser() {
      return isAuthenticated() && getUserRole() in ['super_admin', 'admin', 'director', 'utp_head', 'inspector', 'teacher', 'docente_volante'];
    }

    // Usuarios anónimos autenticados (kiosko de canje via QR)
    function isKiosko() {
      return request.auth != null;
    }

    match /incentivo_estrellas/{studentId} {
      allow read: if isKiosko();
      allow write: if isIncentivoUser();
      // Kiosko solo puede descontar (estrellas decrece) y solo el campo estrellas
      allow update: if isKiosko()
        && request.resource.data.estrellas < resource.data.estrellas
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['estrellas']);
    }

    match /incentivo_transacciones/{txId} {
      allow read: if isIncentivoUser();
      allow create: if isIncentivoUser() || isKiosko();
      allow update, delete: if isAdmin();
    }

    match /incentivo_config/{docId} {
      allow read: if isKiosko();
      allow write: if isManagement();
    }

    match /incentivo_productos/{docId} {
      allow read: if isKiosko();
      allow create, delete: if isManagement();
      // Gestión completa para management; kiosko solo puede decrementar stock en 1
      allow update: if isManagement()
        || (isKiosko()
          && request.resource.data.stock == resource.data.stock - 1
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stock']));
    }

    // ============================================
    // AGENDA CONTENIDO (llenada por el docente)
    // ============================================
    match /agenda_contenido/{docId} {
      allow read: if isAuthenticated();
      // El docente solo escribe documentos bajo su propio uid
      allow create, update: if isAuthenticated() &&
        request.resource.data.docenteId == request.auth.uid;
      allow delete: if isAuthenticated() && (
        resource.data.docenteId == request.auth.uid ||
        isAdmin() || isUTP()
      );
    }

    // ============================================
    // AVISOS PROFESOR JEFE (agenda semanal tabular)
    // ============================================
    match /avisos_profesor_jefe/{curso} {
      allow read: if isAuthenticated();
      // UTP y admins pueden escribir cualquier curso; el profesor jefe solo el suyo
      allow write: if isUTP() || (
        isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isHeadTeacher', false) == true &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('headTeacherOf', '') == curso
      );
    }

    // ============================================
    // INTERFERIADOS (días sin clases institucionales)
    // ============================================
    match /interferiados/{dateStr} {
      // Todos los autenticados pueden leer (afecta todos los calendarios)
      allow read: if isAuthenticated();
      // Solo jefa UTP y admins pueden crear/modificar/eliminar
      allow write: if isUTP();
    }
  }
}
