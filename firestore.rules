rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper: Validar autenticacion
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper: Validar si es administrador buscando en la coleccion users
    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'super_admin']);
    }

    // 1. Coleccion de Usuarios
    match /users/{userId} {
      // Todos pueden leer perfiles (necesario para ver nombres de profesores, etc)
      allow read: if isAuthenticated();
      // Solo el usuario mismo o un admin puede editar su perfil
      allow create, update: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      // Solo admins pueden eliminar usuarios
      allow delete: if isAdmin();
    }

    // 2. Resto de Colecciones (Print requests, Tickets, etc.)
    match /{collection}/{docId} {
      // Lectura permitida a usuarios de la app
      allow read: if isAuthenticated();
      
      // Escritura segura:
      // - Si el documento tiene un campo 'userId', el usuario autenticado debe coincidir con ese userId.
      // - Un administrador puede crear, modificar o eliminar cualquier documento.
      allow create: if isAuthenticated() && (
        !request.resource.data.keys().hasAll(['userId']) || 
        request.resource.data.userId == request.auth.uid || 
        isAdmin()
      );
      
      allow update, delete: if isAuthenticated() && (
        !resource.data.keys().hasAll(['userId']) || 
        resource.data.userId == request.auth.uid || 
        isAdmin()
      );
    }
  }
}
