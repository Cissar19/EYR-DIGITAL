# IP fija de la impresora en la red local (sin http://)
PRINTER_IP=192.168.1.100

# Puerto IPP de la impresora (casi siempre 631)
PRINTER_PORT=631

# Ruta de impresión IPP — prueba con /ipp/print o /printers/NOMBRE_IMPRESORA
PRINTER_PATH=/ipp/print

# Copias extra (0 = solo matrícula del curso, positivo = agrega extras, negativo = resta)
EXTRA_COPIES=0
